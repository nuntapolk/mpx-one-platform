{
  "realm": "mpx-one",
  "displayName": "MPX-ONE Governance",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "clients": [
    {
      "clientId": "mpx-web",
      "name": "MPX-ONE Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3000/*",
        "https://mpx-one.example.com/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://mpx-one.example.com"
      ],
      "protocol": "openid-connect"
    },
    {
      "clientId": "mpx-api",
      "name": "MPX-ONE API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "mpx-bff",
      "name": "MPX-ONE BFF (server-side)",
      "enabled": true,
      "publicClient": false,
      "secret": "mpx-bff-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/api/auth/callback",
        "https://mpx-one.example.com/api/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://mpx-one.example.com"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*##https://mpx-one.example.com/*"
      },
      "protocolMappers": [
        {
          "name": "audience-mpx-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "mpx-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Platform administrator"
      },
      {
        "name": "dpo",
        "description": "Data Protection Officer"
      },
      {
        "name": "it-admin",
        "description": "IT governance administrator"
      },
      {
        "name": "viewer",
        "description": "Read-only access"
      }
    ]
  },
  "users": [
    {
      "username": "admin@mpx.local",
      "email": "admin@mpx.local",
      "firstName": "MPX",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "mpx1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "dpo@mpx.local",
      "email": "dpo@mpx.local",
      "firstName": "DPO",
      "lastName": "Officer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "mpx1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "dpo"
      ]
    }
  ]
}