# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=mpx_one
POSTGRES_USER=mpx
POSTGRES_PASSWORD=mpxsecret

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=redissecret

# ── Keycloak ───────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin1234
KEYCLOAK_REALM=mpx-one
KEYCLOAK_URL=http://localhost:8080

# ── Auth (BFF) ─────────────────────────────────────────────────
# AUTH_ENABLED=false → dev bypass (no Keycloak needed). true → enforce Keycloak login.
# Set on BOTH api (mpx-governance-api) and web (mpx-one).
AUTH_ENABLED=false
# Frontend BFF (mpx-one/.env.local)
NEXT_PUBLIC_API_URL=/api/proxy
API_INTERNAL_URL=http://localhost:4000
APP_URL=http://localhost:3000
KEYCLOAK_ISSUER=http://localhost:8080/realms/mpx-one
KEYCLOAK_BFF_CLIENT_ID=mpx-bff
KEYCLOAK_BFF_CLIENT_SECRET=mpx-bff-dev-secret

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin1234

# ── Grafana ────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin1234

# ── AI Service ─────────────────────────────────────────────────
AI_SERVICE_TOKEN=change-me-in-production

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
