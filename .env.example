# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=mpx_one
POSTGRES_USER=mpx
POSTGRES_PASSWORD=mpxsecret

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=redissecret

# ── Keycloak ───────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin1234
KEYCLOAK_REALM=mpx-one

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin1234

# ── Grafana ────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin1234

# ── AI Service ─────────────────────────────────────────────────
AI_SERVICE_TOKEN=change-me-in-production

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
