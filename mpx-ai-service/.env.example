APP_NAME=MPX-ONE AI Service
ENV=development
PORT=8000

# Read-only DB role recommended in production
DATABASE_URL=postgresql://mpx:mpxsecret@localhost:5432/mpx_one

# NestJS core API
CORE_API_URL=http://localhost:4000

# Shared secret with NestJS for service-to-service calls
INTERNAL_TOKEN=change-me-in-production

# Keycloak (Phase 2)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=mpx-one

# Embeddings (Phase 2)
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384
